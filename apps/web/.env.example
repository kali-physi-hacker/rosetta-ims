# ── Backend base URL ────────────────────────────────────────────────────────
# Leave VITE_API_URL UNSET for local development: the app then calls the same-origin
# `/api/v1` prefix and Vite proxies `/api/*` to VITE_API_PROXY_TARGET (see vite.config.ts),
# so the backend needs no CORS changes for localhost.
#
# In production, set this to the backend origin, e.g. https://178.128.127.5.nip.io.
# The frontend appends VITE_API_VERSION, which defaults to v1.
# VITE_API_URL=
# VITE_API_VERSION=v1

# Where the dev server forwards `/api/*` (used by `vite` dev only).
VITE_API_PROXY_TARGET=https://178.128.127.5.nip.io
