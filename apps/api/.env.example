# ─────────────────────────────────────────────────────────────────────────────
# Rosetta IMS API — droplet environment.  Copy to `.env` and fill in real values.
#   cp .env.example .env  &&  nano .env
# `.env` is gitignored — never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# === Public hostname (REQUIRED) ============================================
# The domain you point at this droplet's IP. Caddy gets a TLS cert for it.
# Must be HTTPS-capable because the Vercel frontend is HTTPS.
API_DOMAIN=api.your-domain.com

# === CORS (REQUIRED) =======================================================
# Comma-separated, NO spaces. The app also always allows rosetta-ims*.vercel.app
# via a built-in regex, so this is mainly for localhost dev + any custom domain.
ALLOWED_ORIGINS=https://rosetta-ims.vercel.app,http://localhost:3001,http://localhost:3000

# === Auth (REQUIRED) =======================================================
# Signs JWT login tokens. MUST be a long random string in production — if it
# stays at the default, tokens are forgeable. Generate one with:
#   openssl rand -hex 32
JWT_SECRET=change-me-openssl-rand-hex-32

# Optional extra gate: if set, every non-public request must send this as the
# X-API-Key header OR a Bearer JWT. Leave EMPTY to rely on JWT only (default).
IMS_API_KEY=

# === Database (Postgres — Phase 2, option B) ===============================
# IMS defaults to SQLite (./data/ims.db). The compose bundles a Postgres container
# under the "postgres" profile, so it is DORMANT and a normal deploy needs NONE of these.
# They're only used at the Postgres cutover (docs/postgres-migration-runbook.md): set them,
# `docker compose --profile postgres up -d postgres`, migrate, then set DATABASE_URL.
# Rollback = blank DATABASE_URL + restart api (the migration never modifies SQLite).
POSTGRES_USER=ims
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=ims
# Leave EMPTY to stay on SQLite. To cut over:
#   DATABASE_URL=postgresql+psycopg2://ims:<POSTGRES_PASSWORD>@postgres:5432/ims
DATABASE_URL=

# === algo-dashboard live-data sync (optional — Phase 3) ====================
# Read-only pull of real sales velocity + inventory expiry from the algo-dashboard
# Postgres (the "Sync live data" button / POST /sync/algo). Unset = sync disabled.
# The api container must reach that DB (share the `edge` docker network).
# See docs/algo-dashboard-sync-setup.md.
#   ALGO_DASHBOARD_DATABASE_URL=postgresql+psycopg2://<user>:<pw>@algo-dashboard-db-1:5432/<db>
ALGO_DASHBOARD_DATABASE_URL=

# === Anthropic (REQUIRED for AI extraction/tagging/species) ================
ANTHROPIC_API_KEY=sk-ant-...

# === Google Sheets push (REQUIRED for sheet sync) ==========================
# Provide credentials as a mounted FILE: put the service-account JSON at
# ./secrets/google-sa.json on the droplet (compose mounts it to /secrets and
# sets GOOGLE_SA_KEY_PATH automatically). Leave GOOGLE_SA_KEY_JSON empty.
GOOGLE_SA_KEY_JSON=
# SSOT spreadsheet the verified rows are pushed to. Defaults are baked into the code
# (the v7 sheet) — leave these COMMENTED OUT unless the sheet changes. Do NOT set them
# to an empty value: a blank SSOT_SHEET_GID / SSOT_DATA_START_ROW crashes startup.
# SSOT_SHEET_ID=
# SSOT_SHEET_GID=
# SSOT_DATA_START_ROW=

# === Email (optional — access requests + user invites) =====================
RESEND_API_KEY=
# Sender — the domain MUST be verified in Resend (resend.com/domains) to email arbitrary
# recipients. onboarding@resend.dev only delivers to the Resend account owner.
EMAIL_FROM=Rosetta IMS <noreply@algogroup.io>
ADMIN_EMAIL=chris@algogroup.io
# Resend SMTP port. DigitalOcean (and most clouds) block 465/587; Resend also serves TLS on
# 2465 (and STARTTLS on 2587), which clouds leave open. Default 2465.
SMTP_PORT=2465
# Public frontend URL — used to build the /onboard?token=… link in invite emails.
APP_URL=https://rosetta-ims.vercel.app

# === Rosetta TECH dashboard fields (optional) ==============================
ROSETTA_TECH_API_URL=
ROSETTA_TECH_API_KEY=

# === Runtime tuning (optional) =============================================
# uvicorn worker processes. 1 is memory-safe; raise to 2 on a >=2GB droplet.
WEB_CONCURRENCY=1

# === Client SSOT data pipeline (REQUIRED to run clientssot/refresh_all.py) ====
# Read-only pulls into the clientssot_* tables. Not needed just to SERVE the
# Clientbase (that only reads the DB) — only to re-ingest/refresh customer data.
# DaySmart Vet (clinic POS — Ohana): OAuth2 client-credentials, scope=APIService
DAYSMART_BASE_URL=
DAYSMART_API_KEY=
DAYSMART_CLIENT_ID=
DAYSMART_CLIENT_SECRET=
# Shopify (PetProject store) — DURABLE Admin API token from the "Vetra SSOT" custom app
SHOPIFY_DOMAIN=hongkongpetproject.myshopify.com
SHOPIFY_TOKEN=shpat_...
# Klaviyo (CRM/consent) — private key
KLAVIYO_API_KEY=pk_...
# ChatArchitect (WhatsApp Business API) — opt-in pull + (future) blasts
CHATARCHITECT_BASE=https://api.chatarchitect.com
CHATARCHITECT_APP_ID=
CHATARCHITECT_APP_SECRET=
# Slack (WhatsApp-mirror CS channels) — bot token xoxb-… (channels:history, chat:write)
SLACK_TOKEN=xoxb-...
